# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://krist:915678@localhost:5432/heraccess"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change_me_access_secret_64_chars_minimum_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
JWT_REFRESH_SECRET="change_me_refresh_secret_64_chars_minimum_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173"

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
