# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Vercel автоматически выставляет VERCEL=1 — не задавай вручную

# ─── Database ─────────────────────────────────────────────────────────────────
# Локально:
DATABASE_URL="postgresql://postgres:password@localhost:5432/heraccess"

# Vercel Postgres (Neon) — берётся из Vercel Dashboard → Storage → Connect:
# DATABASE_URL="postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/heraccess?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Генерация: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change_me_access_secret_64_chars_minimum"
JWT_REFRESH_SECRET="change_me_refresh_secret_64_chars_minimum"

JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Локально:
CLIENT_URL="http://localhost:5173"

# Прод — несколько origins через запятую:
# CLIENT_URL="https://heraccess.vercel.app,https://heraccess.io"

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Получить ключ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."
