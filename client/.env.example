# ─── API ──────────────────────────────────────────────────────────────────────
# Локально: Vite proxy перенаправляет /api → localhost:4000, переменная не нужна.
#
# Прод: URL сервера (Vercel Project #2 — heraccess-server).
# Без этого клиент будет слать /api/* запросы на свой же домен и получать 404.
#
VITE_API_URL=https://heraccess-server.vercel.app

# ─── Media (видео и аудио) ────────────────────────────────────────────────────
# Локально: оставь пустым — файлы берутся из client/public/media/
# Прод: URL публичного Cloudflare R2 бакета (или другого CDN)
#
# VITE_MEDIA_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev
